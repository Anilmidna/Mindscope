# Database
DATABASE_URL=postgresql://user:password@localhost:5432/mindscope

# Google OAuth (stored in AWS Secrets Manager in production)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback

# JWT
JWT_SECRET_KEY=your-jwt-secret-key-min-32-chars
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# AWS
AWS_REGION=us-east-1
# Local dev only — ECS tasks use the attached IAM role, no static keys needed
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key

# S3
S3_BUCKET_NAME=mindscope-reports

# SES
SES_FROM_EMAIL=reports@mindscope.ai

# Bedrock — must use cross-region inference profile IDs, not direct model IDs
BEDROCK_MODEL_ID=us.anthropic.claude-sonnet-4-6
BEDROCK_OPUS_MODEL_ID=us.anthropic.claude-opus-4-7

# Admin — gates /admin/* (model switching) and /b2b/* (org/invite creation)
# Fails closed with 403 if unset — do not leave empty in production.
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
# Store in AWS Secrets Manager, never commit the real value.
ADMIN_API_KEY=your-admin-api-key-min-32-chars

# App
APP_ENV=development
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
