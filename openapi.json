              "application/json": {
                "schema": {}
              }
            }
          }
        }
      },
      "put": {
        "tags": [
          "admin"
        ],
        "summary": "Update Model",
        "description": "Change the default model for a pipeline stage at runtime.\nTakes effect immediately \u2014 no restart needed.\n\nExample body:\n    {\"stage\": \"report_generation\", \"model\": \"sonnet\"}\n    {\"stage\": \"report_generation\", \"model\": \"haiku\", \"temperature\": 0.2}\n    {\"stage\": \"question_generation\", \"model\": \"opus\"}",
        "operationId": "update_model_admin_models_put",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ModelUpdateRequest"
