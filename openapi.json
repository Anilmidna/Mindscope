    "/admin/models": {
      "get": {
        "tags": [
          "admin"
        ],
        "summary": "Get Current Models",
        "description": "Show current model assignments for all pipeline stages.\nUse this to see what's running before making changes.",
        "operationId": "get_current_models_admin_models_get",
