  "components": {
    "schemas": {
      "AccessTokenResponse": {
        "properties": {
          "access_token": {
            "type": "string",
            "title": "Access Token"
          },
          "token_type": {
            "type": "string",
            "title": "Token Type",
            "default": "bearer"
          }
        },
        "type": "object",
        "required": [
          "access_token"
        ],
        "title": "AccessTokenResponse"
      },
      "CreateOrgRequest": {
        "properties": {
          "org_name": {
            "type": "string",
            "title": "Org Name"
          },
          "context_of_origin": {
            "type": "string",
            "title": "Context Of Origin"
          },
          "total_licenses": {
            "type": "integer",
            "title": "Total Licenses"
          },
          "created_by": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Created By"
          },
          "expires_at": {
            "anyOf": [
              {
                "type": "string",
                "format": "date-time"
              },
              {
                "type": "null"
              }
            ],
            "title": "Expires At"
          }
        },
        "type": "object",
        "required": [
          "org_name",
          "context_of_origin",
          "total_licenses"
        ],
        "title": "CreateOrgRequest"
      },
      "GoogleCallbackRequest": {
        "properties": {
          "code": {
            "type": "string",
            "title": "Code"
          },
          "code_verifier": {
            "type": "string",
            "title": "Code Verifier"
          },
          "redirect_uri": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Redirect Uri"
          }
        },
        "type": "object",
        "required": [
          "code",
          "code_verifier"
        ],
        "title": "GoogleCallbackRequest"
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "type": "array",
            "title": "Detail"
          }
        },
        "type": "object",
        "title": "HTTPValidationError"
      },
      "IntakeFormRequest": {
        "properties": {
          "life_stage": {
            "type": "string",
            "title": "Life Stage",
            "description": "Determines RIASEC persona (student/professional)"
          },
          "domain": {
            "anyOf": [
              {
                "type": "string",
                "maxLength": 200
              },
              {
                "type": "null"
              }
            ],
            "title": "Domain"
          },
          "specialization": {
            "anyOf": [
              {
                "type": "string",
                "maxLength": 100
              },
              {
                "type": "null"
              }
            ],
            "title": "Specialization"
          },
          "future_goals": {
            "type": "string",
            "maxLength": 200,
            "title": "Future Goals"
          },
          "satisfaction": {
            "type": "integer",
            "maximum": 10.0,
            "minimum": 1.0,
            "title": "Satisfaction"
          },
          "challenges": {
            "anyOf": [
              {
                "type": "string",
                "maxLength": 200
              },
              {
                "type": "null"
              }
            ],
            "title": "Challenges"
          },
          "education_level": {
            "anyOf": [
              {
                "type": "string",
                "maxLength": 100
              },
              {
                "type": "null"
              }
            ],
            "title": "Education Level"
          },
          "preferred_work_style": {
            "anyOf": [
              {
                "type": "string",
                "maxLength": 100
              },
              {
                "type": "null"
              }
            ],
            "title": "Preferred Work Style"
          },
